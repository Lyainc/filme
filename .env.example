# KOBIS 영화 정보 조회 API
KOBIS_API_KEY=

# Vercel AI Gateway — OCR (gpt-4o-mini vision)
# 기본 인증은 OIDC: `vercel env pull .env.local` 이 VERCEL_OIDC_TOKEN(~24h)을 자동 발급하고
# 배포 환경에선 키리스로 동작해요. 로컬/CI에서 정적 키를 쓰려면 아래에 발급 키를 넣으세요.
AI_GATEWAY_API_KEY=

# Upstash Redis — public provider API rate limit.
# 로컬/테스트에서는 선택이지만, production에서는 OCR/KOBIS API 남용 방지를 위해 필수예요.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
