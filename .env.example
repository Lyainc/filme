# KOBIS 영화 정보 조회 API
KOBIS_API_KEY=

# Google AI Studio — OCR (gemini-3.1-flash-lite vision). AI Gateway 대신 벤더 직결이에요(#125).
# https://aistudio.google.com/apikey 에서 발급
GOOGLE_GENERATIVE_AI_API_KEY=

# Upstash Redis — public provider API rate limit.
# 로컬/테스트에서는 선택이지만, production에서는 OCR/KOBIS API 남용 방지를 위해 필수예요.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
