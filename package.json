{
  "name": "phototicket-maker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "bun scripts/generate-asset-manifest.ts && bun scripts/vendor-tesseract.ts",
    "dev": "bun --bun next dev",
    "prebuild": "bun scripts/generate-asset-manifest.ts && bun scripts/vendor-tesseract.ts",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "gen:assets": "bun scripts/generate-asset-manifest.ts",
    "gen:tesseract": "bun scripts/vendor-tesseract.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "next": "^16.0.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-easy-crop": "^5.5.7",
    "tailwindcss": "^3.4.18",
    "tesseract.js": "^7.0.0"
  },
  "packageManager": "bun@1.3.14",
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "autoprefixer": "^10.4.22",
    "bun-types": "^1.3.14",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
